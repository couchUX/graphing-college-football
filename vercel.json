{
  "rewrites": [
    {
      "source": "/api/cfbd/:path*",
      "destination": "/api/cfbd?proxyPath=:path*"
    },
    {
      "source": "/games",
      "destination": "/games.html"
    },
    {
      "source": "/ratings",
      "destination": "/ratings.html"
    },
    {
      "source": "/trends",
      "destination": "/trends.html"
    },
    {
      "source": "/",
      "destination": "/games.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
