{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/games",
      "destination": "/games.html"
    },
    {
      "source": "/ratings",
      "destination": "/ratings.html"
    },
    {
      "source": "/trends",
      "destination": "/trends.html"
    },
    {
      "source": "/",
      "destination": "/games.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
